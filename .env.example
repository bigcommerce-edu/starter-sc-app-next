# BigCommerce OAuth app credentials (Dev Portal > your app > OAuth)
BIGCOMMERCE_CLIENT_ID=
BIGCOMMERCE_CLIENT_SECRET=

# The app's own public origin (e.g. https://my-app.example.com). Used to
# build the OAuth redirect_uri sent to BigCommerce and this app's own
# browser-facing redirects — never derived from the incoming request, since
# behind a proxy or on Cloudflare the request's observed host/scheme isn't
# guaranteed to match the public origin BigCommerce actually calls back to.
APP_ORIGIN=

# Developer branding shown in the app shell's support panel.
# Filename of the logo image, expected to be in the public/ directory.
DEVELOPER_LOGO_FILENAME=northlight-logo.svg
DEVELOPER_NAME="Northlight Apps"
SUPPORT_EMAIL=support@northlightapps.dev
SUPPORT_URL=https://northlightapps.dev/support
SUPPORT_PHONE="+1 (555) 010-0142"

# Controls how the app sources data. Defaults to MOCK when unset.
#   MOCK        - No real API calls are made; in-memory mock data is used for
#                 everything. No authentication, no external requests.
#   STATIC      - All API requests use a single BigCommerce API token from
#                 STATIC_STORE_TOKEN below. Suitable for local development
#                 against one real store, not for multi-user production use.
#   MULTITENANT - API tokens are looked up per-user from durable storage based
#                 on the authenticated session. This is the production mode.
DATA_MODE=MOCK

# Simulates network latency for every mock-mode request, so loading/Suspense
# states are visible during local development and demos. Each request waits a
# random number of milliseconds between these two values (inclusive) before
# resolving. Leave both unset (or omit either one) to disable the delay
# entirely, e.g. when running automated tests. Unused outside DATA_MODE=MOCK.
MOCK_REQUEST_DELAY_MIN_MS=500
MOCK_REQUEST_DELAY_MAX_MS=2000

# BigCommerce store hash and API token used for every request when DATA_MODE=STATIC.
# Unused (and not required) in MOCK or MULTITENANT mode.
STATIC_STORE_HASH=
STATIC_STORE_TOKEN=

# Set to "true" to log every outgoing BigCommerce API request (method, URL,
# status, duration) to the console. Off by default. Since a request only
# ever fires on a `use cache` miss, this also serves as a cache-observability
# signal: a logged request means a miss just occurred, and no log on a
# repeat page load means it was served from cache.
LOG_API_REQUESTS=FALSE

# Controls what DB driver is used for credentials storage. Valid values:
#   - SQLITE
CREDENTIALS_STORE_DRIVER=SQLITE

# Path to the local SQLite file used for credentials storage when
# CREDENTIALS_STORE_DRIVER=SQLITE. Only meaningful for that driver — other
# drivers (D1, Postgres) will introduce their own connection-string-style
# setting rather than reusing this one. Defaults to ./data/credentials.sqlite
# if unset.
CREDENTIALS_SQLITE_PATH=

# Symmetric key used to encrypt stored store access tokens at rest
CREDENTIALS_ENCRYPTION_KEY=
